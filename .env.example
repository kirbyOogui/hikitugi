# PostgreSQL接続文字列
# 例) postgresql://user:password@localhost:5432/handover_db
# Renderの場合はDBダッシュボードの"Internal Database URL"を使う
DATABASE_URL=postgresql://user:password@localhost:5432/handover_db

# Cloudinary（ダッシュボードの「API Environment variable」から取得できる3項目）
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
